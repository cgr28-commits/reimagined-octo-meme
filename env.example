# Copy to .env.local for local development, then run:
#   npm run dev:addresses   (Cloudflare Worker on http://127.0.0.1:8787)
#   npm run dev             (Next.js site on http://localhost:3000)

GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Production GitHub Pages build — set as a GitHub Actions secret after deploying the worker:
# NEXT_PUBLIC_ADDRESS_API_URL=https://my-airport-taxi-addresses.your-subdomain.workers.dev
